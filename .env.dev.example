# =========================================================
# FluxFiles Development Environment Example
# 这是测试环境模板文件，请复制为 .env.dev 后按实际环境修改。
# 当前服务器上的测试环境使用共享的主 PostgreSQL / Redis，
# 但通过独立数据库和独立 Redis 逻辑库隔离。
# =========================================================

APP_NAME=FluxFiles
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_EXTERNAL_URL=https://test.example.com/fluxfiles
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8

POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=fluxfiles_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-dev-db-password
POSTGRES_SSLMODE=disable

REDIS_ADDR=host.docker.internal:6379
REDIS_PASSWORD=replace-with-dev-redis-password
REDIS_DB=1
REDIS_PREFIX=fluxfiles-dev

JWT_SECRET=replace-with-a-long-random-dev-secret
JWT_EXPIRE_HOURS=24
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisStrongPassword123!
LOGIN_FAILURE_LIMIT=5
LOGIN_BLOCK_MINUTES=15
BLACKLIST_IPS=

MAX_UPLOAD_SIZE_MB=200
ALLOWED_FILE_EXTENSIONS=.zip,.rar,.7z,.pdf,.txt,.csv,.xlsx,.xls,.doc,.docx,.ppt,.pptx,.jpg,.jpeg,.png,.mp4,.mp3
ALLOWED_MIME_TYPES=application/zip,application/x-rar-compressed,application/x-7z-compressed,application/pdf,text/plain,text/csv,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,image/jpeg,image/png,video/mp4,audio/mpeg

OSS_REGION=cn-shenzhen
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET=your-dev-bucket
OSS_ACCESS_KEY_ID=your-dev-access-key-id
OSS_ACCESS_KEY_SECRET=your-dev-access-key-secret
OSS_BASE_PATH=fluxfiles/test
OSS_SIGNED_URL_TTL_MINUTES=10
OSS_DELETE_MODE=soft

RATE_LIMIT_LOGIN=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_DOWNLOAD=60
RATE_LIMIT_DOWNLOAD_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=300
RATE_LIMIT_LIST=120
RATE_LIMIT_LIST_WINDOW_SECONDS=60

WEB_PORT=28081
API_PORT=28080
VITE_API_BASE_URL=/api
