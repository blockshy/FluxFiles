# =========================================================
# FluxFiles Environment Configuration Example
# 这是环境变量模板文件，请复制为 .env 后按实际环境修改。
# 修改后如使用容器运行，请重新执行：
# docker compose up -d --build
# =========================================================

# =========================================================
# 1. Application / 应用基础配置
# =========================================================

# 应用名称，仅用于日志、展示和系统标识。
# 一般保持为 FluxFiles 即可。
APP_NAME=FluxFiles

# 运行环境，可选值通常为 development / production。
# production 会启用更保守的服务行为与日志级别。
APP_ENV=production

# 后端 API 在容器或本机内监听的地址。
# Docker 内建议保持 0.0.0.0，表示接受所有网卡请求。
APP_HOST=0.0.0.0

# 后端 API 进程监听端口。
# 需要与 docker-compose 中 api 服务映射端口保持一致。
APP_PORT=8080

# 系统对外访问的根地址，用于后续扩展邮件通知、回调地址、
# OpenAPI 文档、前端跳转地址等场景。
# 本地一般填 http://localhost，生产环境填你的正式域名。
APP_EXTERNAL_URL=http://localhost

# 受信任代理列表，用于让 Gin 正确识别真实客户端 IP。
# 如果前面挂了 Nginx、负载均衡或 CDN，需要把对应代理网段加入这里。
# 多个值用英文逗号分隔。
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8


# =========================================================
# 2. PostgreSQL / 数据库配置
# =========================================================

# PostgreSQL 主机名。
# Docker Compose 内应填写服务名 postgres；
# 如果接外部数据库，可改成实际 IP 或域名。
POSTGRES_HOST=postgres

# PostgreSQL 端口，默认 5432。
POSTGRES_PORT=5432

# 业务数据库名称。
# 第一次部署时会由 postgres 容器自动初始化。
POSTGRES_DB=fluxfiles

# 数据库用户名。
# 生产环境请使用专用账号，不要直接使用超级管理员。
POSTGRES_USER=fluxfiles

# 数据库密码。
# 生产环境请替换为高强度密码，并结合密钥管理系统或 CI/CD Secret 管理。
POSTGRES_PASSWORD=fluxfiles_password

# PostgreSQL SSL 模式。
# 本地容器联调一般使用 disable；
# 云数据库或公网连接建议按实际情况改为 require / verify-full。
POSTGRES_SSLMODE=disable


# =========================================================
# 3. Redis / 缓存与限流配置
# =========================================================

# Redis 地址，格式为 host:port。
# Docker Compose 内使用 redis:6379。
REDIS_ADDR=redis:6379

# Redis 密码。
# 如果 Redis 未启用密码可留空；
# 生产环境强烈建议设置密码并限制网络访问。
REDIS_PASSWORD=

# Redis 数据库编号，默认 0。
# 若与其他项目共用 Redis，可改用不同 DB 做隔离。
REDIS_DB=0

# Redis Key 前缀。
# 用于区分当前项目写入的限流、登录失败计数等键名。
# 多项目共用 Redis 时不要重复。
REDIS_PREFIX=fluxfiles


# =========================================================
# 4. Security / 认证与安全配置
# =========================================================

# JWT 签名密钥。
# 必须替换为足够长、足够随机的字符串，否则管理员登录令牌不安全。
# 建议长度至少 32 字符，可用密码生成器生成。
JWT_SECRET=replace-with-a-long-random-secret

# JWT 有效期，单位为小时。
# 例如 24 表示登录后 24 小时过期。
# 后台安全要求更高时可适当缩短，例如 8 或 12。
JWT_EXPIRE_HOURS=24

# 首次启动时自动创建的管理员用户名。
# 仅当数据库中还没有任何 admin 用户时才会生效。
ADMIN_BOOTSTRAP_USERNAME=admin

# 首次启动时自动创建的管理员密码。
# 部署后请立即替换成强密码，避免默认口令风险。
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisStrongPassword123!

# 同一账号 + IP 在登录失败多少次后触发临时封禁。
# 值越小越安全，但也更容易误伤正常用户。
LOGIN_FAILURE_LIMIT=5

# 登录失败达到阈值后封禁时长，单位为分钟。
# 例如 15 表示 15 分钟内拒绝继续尝试。
LOGIN_BLOCK_MINUTES=15

# IP 黑名单。
# 命中后会被全局拒绝访问。
# 多个 IP 用英文逗号分隔；留空表示不启用静态黑名单。
# 例：192.168.1.10,8.8.8.8
BLACKLIST_IPS=


# =========================================================
# 5. Upload Policy / 上传策略
# =========================================================

# 单个上传文件的最大大小，单位 MB。
# 后端会拒绝超过该限制的文件。
# 需要与 Nginx 的 client_max_body_size 保持匹配或略小。
MAX_UPLOAD_SIZE_MB=200

# 允许上传的文件扩展名白名单。
# 多个扩展名用英文逗号分隔，必须带点号。
# 建议只保留你真实业务需要的类型，尽量不要放开脚本或可执行文件。
ALLOWED_FILE_EXTENSIONS=

# 允许上传的 MIME 类型白名单。
# 后端会结合文件内容检测出的 MIME 类型做校验。
# 建议与扩展名白名单保持一致，双重控制更安全。
ALLOWED_MIME_TYPES=


# =========================================================
# 6. Alibaba Cloud OSS / 对象存储配置
# =========================================================

# OSS 所在地域代码。
# 例如杭州是 cn-hangzhou，深圳是 cn-shenzhen。
# 必须与你实际 Bucket 所在地域一致。
OSS_REGION=cn-hangzhou

# OSS 访问域名。
# 一般格式为 https://oss-<region>.aliyuncs.com
# 请根据你的地域调整。
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# OSS Bucket 名称。
# 需要先在阿里云 OSS 控制台中创建。
OSS_BUCKET=your-bucket

# 阿里云 AccessKey ID。
# 建议使用最小权限的 RAM 用户，不要直接用主账号 AccessKey。
OSS_ACCESS_KEY_ID=your-access-key-id

# 阿里云 AccessKey Secret。
# 与 AccessKey ID 成对使用，必须妥善保管，避免提交到公开仓库。
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# 上传到 OSS 后对象 Key 的统一前缀目录。
# 例如设为 fluxfiles，则对象会组织在 fluxfiles/2026/04/09/... 之下。
# 用于区分环境或业务模块，推荐保留。
OSS_BASE_PATH=fluxfiles

# 下载签名 URL 的有效期，单位为分钟。
# 数值越短越安全；常见可设为 5 到 15 分钟。
OSS_SIGNED_URL_TTL_MINUTES=10

# 删除策略。
# sync 表示删除数据库记录时同步删除 OSS 对象；
# soft 表示仅删除业务记录，不主动删除 OSS 对象，便于后续做异步清理。
OSS_DELETE_MODE=sync


# =========================================================
# 7. Rate Limiting / 限流配置
# =========================================================

# 管理员登录接口在一个时间窗口内允许的最大请求次数。
# 建议设置得相对严格，防止暴力破解。
RATE_LIMIT_LOGIN=10

# 管理员登录限流窗口，单位为秒。
# 与 RATE_LIMIT_LOGIN 搭配使用。
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60

# 公共下载接口在一个时间窗口内允许的最大请求次数。
# 可根据实际流量和防盗刷要求调整。
RATE_LIMIT_DOWNLOAD=60

# 公共下载接口限流窗口，单位为秒。
RATE_LIMIT_DOWNLOAD_WINDOW_SECONDS=60

# 管理后台上传接口在一个时间窗口内允许的最大请求次数。
# 如果后台管理员人数少，这个值可以设得更低。
RATE_LIMIT_UPLOAD=20

# 上传接口限流窗口，单位为秒。
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=300

# 公共文件列表/后台列表查询的限流次数。
# 通常比登录和上传宽松。
RATE_LIMIT_LIST=120

# 列表查询限流窗口，单位为秒。
RATE_LIMIT_LIST_WINDOW_SECONDS=60


# =========================================================
# 8. Port / 对外端口与前端构建配置
# =========================================================

# Web 容器对宿主机暴露的端口。
# 默认 80，对应前台站点和后台页面入口。
# 如果本机 80 端口被占用，可改成 8081、3000 等。
WEB_PORT=80

# API 容器对宿主机暴露的端口。
# 用于调试、直连 API 或被其他服务调用。
API_PORT=8080

# 前端打包时注入的 API 根路径。
# 如果由 Nginx 统一反向代理，保持 /api 即可；
# 如果前后端分域部署，可改成完整地址，例如 https://api.example.com/api
VITE_API_BASE_URL=/api
