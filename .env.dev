# =========================================================
# FluxFiles Development Environment
# 仅用于本地开发 / 测试，不要用于生产环境
# 配合 docker-compose.dev.yml 使用
# =========================================================

APP_NAME=FluxFiles
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_EXTERNAL_URL=http://localhost:8081/fluxfiles
TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fluxfiles_dev
POSTGRES_USER=fluxfiles
POSTGRES_PASSWORD=fluxfiles_dev_password
POSTGRES_SSLMODE=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=fluxfiles-dev

JWT_SECRET=fluxfiles-dev-secret-change-me
JWT_EXPIRE_HOURS=24
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisStrongPassword123!
LOGIN_FAILURE_LIMIT=5
LOGIN_BLOCK_MINUTES=15
BLACKLIST_IPS=

MAX_UPLOAD_SIZE_MB=200
ALLOWED_FILE_EXTENSIONS=
ALLOWED_MIME_TYPES=

OSS_REGION=cn-shenzhen
OSS_ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET=flux-files
OSS_ACCESS_KEY_ID=replace-me
OSS_ACCESS_KEY_SECRET=replace-me
OSS_BASE_PATH=fluxfiles/dev
OSS_SIGNED_URL_TTL_MINUTES=10
OSS_DELETE_MODE=soft

RATE_LIMIT_LOGIN=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_DOWNLOAD=60
RATE_LIMIT_DOWNLOAD_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=300
RATE_LIMIT_LIST=120
RATE_LIMIT_LIST_WINDOW_SECONDS=60

WEB_PORT=8081
API_PORT=18080
POSTGRES_DEV_PORT=15432
REDIS_DEV_PORT=16379
VITE_API_BASE_URL=/api
